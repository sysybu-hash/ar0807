# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Copy the connection string from your Neon project dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED in production — without it a new ephemeral secret is generated
# on every server restart, invalidating all existing sessions.
JWT_SECRET=your-very-long-random-secret-here

# ── Server ─────────────────────────────────────────────────────────────────────
# Optional — defaults to 3847
# PORT=3847
